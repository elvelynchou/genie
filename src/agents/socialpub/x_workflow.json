{
  "workflows": {
    "post_tweet": [
      {
        "step": "navigate",
        "action": "goto",
        "params": { "url": "https://x.com/compose/post" }
      },
      {
        "step": "wait_for_load",
        "action": "wait",
        "params": { "seconds": 5 }
      },
      {
        "step": "inject_native_proxy",
        "action": "inject_semantic_proxy"
      },
      {
        "step": "focus_and_type",
        "action": "type",
        "params": { 
          "selector": "tweetTextarea_0",
          "text": "{content}"
        }
      },
      {
        "step": "wait_before_post",
        "action": "wait",
        "params": { "seconds": 2 }
      },
      {
        "step": "click_post",
        "action": "click",
        "params": { "selector": "tweetButton" }
      },
      {
        "step": "confirm_finish",
        "action": "wait",
        "params": { "seconds": 3 }
      }
    ]
  }
}
