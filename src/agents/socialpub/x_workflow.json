{
  "workflows": {
    "post_tweet": [
      {
        "step": "navigate",
        "action": "goto",
        "params": { "url": "https://x.com/compose/post" }
      },
      {
        "step": "wait_for_load",
        "action": "wait",
        "params": { "seconds": 10 }
      },
      {
        "step": "upload_image",
        "action": "upload",
        "params": { 
          "selector": "input[type='file'][data-testid='fileInput']",
          "file_path": "{image_path}"
        }
      },
      {
        "step": "wait_after_upload",
        "action": "wait",
        "params": { "seconds": 10 }
      },
      {
        "step": "click_text_area",
        "action": "click",
        "params": { "selector": "[data-testid='tweetTextarea_0']" }
      },
      {
        "step": "type_content",
        "action": "type",
        "params": { 
          "selector": "[data-testid='tweetTextarea_0']",
          "text": "{content}"
        }
      },
      {
        "step": "wait_before_post",
        "action": "wait",
        "params": { "seconds": 5 }
      },
      {
        "step": "click_post",
        "action": "click",
        "params": { "selector": "[data-testid='tweetButton']" }
      },
      {
        "step": "confirm_finish",
        "action": "wait",
        "params": { "seconds": 15 }
      }
    ]
  }
}
